# Local mode: bypass Keycloak and use a local SQLite DB with a fixed local user.
# When LOCAL_MODE=true, DATABASE_URL/SESSION_SECRET/FERNET_KEY default to safe
# local values if unset, and the schema is auto-created (no Alembic needed).
# Run: LOCAL_MODE=true uv run --extra web uvicorn youtube_subs_opml.web.main:app
# LOCAL_MODE=false

# Postgres (used by both the db service and app's DATABASE_URL)
POSTGRES_USER=yts
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yts

# Web app
APP_PORT=8000
BASE_URL=http://localhost:8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-to-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# OIDC provider (Keycloak, Authentik, Authelia, etc.)
OIDC_ISSUER=https://sso.example.com/realms/your-realm
OIDC_CLIENT_ID=youtube-subs-opml
OIDC_CLIENT_SECRET=

# Google OAuth — must be a "Web application" client type (Phase 4)
# Authorized redirect URI to register: ${BASE_URL}/auth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
